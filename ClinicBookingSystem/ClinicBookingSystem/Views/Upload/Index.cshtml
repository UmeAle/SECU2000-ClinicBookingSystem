@{
    ViewData["Title"] = "Upload";
}

<div class="container">

    <h2 class="mt-4">Upload Document</h2>

    <p class="text-muted">
        Admin can upload PDF, JPG, or PNG files
    </p>


    <div class="card shadow-sm p-3 mb-4">

        <form method="post"
              enctype="multipart/form-data"
              action="/Upload/UploadFile">

            <input type="file"
                   name="file"
                   class="form-control mb-3" />

            <button class="btn btn-dark">

                Upload

            </button>

        </form>


        <p class="text-danger">
            @ViewBag.Error
        </p>

        @if (TempData["Message"] != null)
        {
            <p class="text-success">
                @TempData["Message"]
            </p>
        }

    </div>



    <h5>Uploaded Documents</h5>

    @if (ViewBag.Documents != null && ViewBag.Documents.Count > 0)
    {
        foreach (var doc in ViewBag.Documents)
        {

            <div class="card p-2 mb-2">

                <b>@doc.FileName</b>

                <p>
                    Uploaded by: @doc.UploadedBy
                </p>

                <p>
                    @doc.UploadDate
                </p>

                <a href="@doc.FilePath" target="_blank">
                    Open File
                </a>


                <form method="post"
                      action="/Upload/DeleteFile"
                      style="display:inline">

                    <input type="hidden"
                           name="id"
                           value="@doc.Id" />

                    <button class="btn btn-sm btn-danger mt-2">

                        Delete

                    </button>

                </form>

            </div>

        }
    }
    else
    {
        <p>No documents uploaded yet</p>
    }

</div>
