 * FILE             : AdminDashboard.cshtml
 * PROJECT          : Clinic Booking System
 * PROGRAMMERS      : Eumee Garcia
 * FIRST VERSION    : 2026-04-12
 * DESCRIPTION      : Displays admin interface for managing appointments and documents.
-->

@model List<ClinicBookingSystem.Models.Appointment>

<style>

    body {
        background: #f5f7fb;
    }

    .page-header {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        color: white;
        padding: 25px;
        border-radius: 12px;
        margin-bottom: 25px;
    }

    .card {
        border-radius: 12px;
    }

    .section-title {
        font-weight: 600;
        margin-bottom: 10px;
    }

</style>

<div class="container">

    <!-- header -->
    <div class="page-header shadow">
        <h2 class="fw-bold mb-1">
            🛠 Admin Dashboard
        </h2>

        <p class="mb-0">
            Manage appointments and uploaded documents
        </p>
    </div>

    <!-- add appointment -->
    <div class="card shadow p-4 mb-4">

        <h5 class="section-title">
            Add Appointment
        </h5>

        <form method="post"
              action="/Appointment/AddAppointment">

            <div class="row">

                <div class="col-md-6">

                    <input name="PatientName"
                           placeholder="Patient Name"
                           class="form-control mb-3"
                           required />
                </div>

                <div class="col-md-6">

                    <input name="DoctorName"
                           placeholder="Doctor Name"
                           class="form-control mb-3"
                           required />
                </div>
            </div>

            <div class="row">

                <div class="col-md-6">

                    <input type="date"
                           name="Date"
                           class="form-control mb-3"
                           required />
                </div>

                <div class="col-md-6">
                    <select name="Time"
                            class="form-control mb-3"
                            required>

                        <option value="">
                            Select Time
                        </option>

                        <option>9:00 AM</option>
                        <option>9:30 AM</option>
                        <option>10:00 AM</option>
                        <option>10:30 AM</option>
                        <option>11:00 AM</option>
                        <option>1:00 PM</option>
                        <option>1:30 PM</option>
                        <option>2:00 PM</option>
                        <option>2:30 PM</option>
                        <option>3:00 PM</option>

                    </select>
                </div>
            </div>


            <input name="Reason"
                   placeholder="Reason for visit"
                   class="form-control mb-3"
                   required />

            <button class="btn btn-dark">

                Add Appointment

            </button>

            <p class="text-danger mt-2">

                @ViewBag.Error

            </p>

        </form>

    </div>



    <!-- appointment list -->
    <div class="card shadow p-4 mb-4">

        <h5 class="section-title">
            Scheduled Appointments
        </h5>

        @if (Model.Count == 0)
        {
            <p class="text-muted">
                No appointments scheduled
            </p>
        }


        @foreach (var a in Model)
        {
            <div class="card shadow-sm p-3 mb-3">

                <div class="row">

                    <div class="col-md-8">

                        <b>
                            @a.PatientName
                        </b>

                        <div>
                            Doctor:
                            @a.DoctorName
                        </div>

                        <div>
                            Date:
                            @a.Date.ToShortDateString()
                        </div>

                        <div>
                            Time:
                            @a.Time
                        </div>

                        <div>
                            Reason:
                            @a.Reason
                        </div>
                    </div>

                    <div class="col-md-4 text-end">

                        <span class="badge bg-success mb-2">
                            @a.Status
                        </span>

                        <br />

                        <a href="/Appointment/Edit/@a.Id"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <form method="post"
                              action="/Appointment/RemoveAppointment"
                              style="display:inline">

                            <input type="hidden"
                                   name="id"
                                   value="@a.Id" />

                            <button class="btn btn-sm btn-danger">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- uploaded files -->
    <div class="card shadow p-4">

        <h5 class="section-title">
            Uploaded Documents
        </h5>


        @if (ViewBag.Documents != null &&
                ViewBag.Documents.Count > 0)
        {
            foreach (var doc in ViewBag.Documents)
            {

                <div class="card p-2 mb-2">
                    <div class="d-flex justify-content-between">

                        <div>
                            📄 @doc.FileName
                        </div>

                        <div>

                            <a href="@doc.FilePath"
                               target="_blank"
                               class="btn btn-sm btn-outline-dark">
                                View
                            </a>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">
                No documents uploaded yet
            </p>
        }
    </div>
</div>