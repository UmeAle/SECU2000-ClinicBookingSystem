@model List<ClinicBookingSystem.Models.Appointment>

<div class="container">

	<h2 class="fw-bold mt-4">
		Admin Dashboard
	</h2>

	<p class="text-muted">
		Create and manage appointment bookings
	</p>

	<!-- Search bar -->
	<div class="card shadow-sm p-3 mb-4">

		<h5>Search</h5>

		<div class="row">

			<div class="col-md-6">
				<input class="form-control"
					   placeholder="Search appointments..." />
			</div>

			<div class="col-md-3">
				<input type="date"
					   class="form-control" />
			</div>

			<div class="col-md-3">
				<input type="time"
					   class="form-control" />
			</div>
		</div>
	</div>

	<!-- Add appointment -->
	<div class="card shadow-sm p-3 mb-4">

		<h5>Add Appointment</h5>

		<form method="post"
			  action="/Appointment/AddAppointment">

			<input name="PatientName"
				   placeholder="Patient Name"
				   class="form-control mb-2" />

			<input name="DoctorName"
				   placeholder="Doctor Name"
				   class="form-control mb-2" />

			<input type="date"
				   name="Date"
				   class="form-control mb-2" />

			<input type="time"
				   name="Time"
				   class="form-control mb-2" />

			<input name="Reason"
				   placeholder="Reason"
				   class="form-control mb-3" />

			<button class="btn btn-dark">
				Add Appointment
			</button>
		</form>
	</div>

	<h5>Appointments</h5>

	@foreach (Appointment a in Model)
	{
		<div class="card shadow-sm p-3 mb-3">

			<b>
				@a.PatientName
			</b>

			<p class="mb-1">
				Doctor: @a.DoctorName
			</p>

			<p class="mb-1">
				@a.Date.ToShortDateString()
			</p>

			<p>
				@a.Time
			</p>

			<p>
				Reason: @a.Reason
			</p>

			<span class="badge bg-success">
				@a.Status
			</span>
		</div>
	}
</div>