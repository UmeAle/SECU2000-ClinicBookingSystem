@{
    ViewBag.HideNavbar = true;
}

<style>

    body {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        min-height: 100vh;
    }

    .login-card {
        border-radius: 15px;
    }

    .logo {
        font-size: 50px;
    }

</style>

<div class="container">

    <div class="row justify-content-center align-items-center vh-100">

        <div class="col-md-4">

            <div class="card shadow-lg p-4 login-card">

                <div class="text-center mb-3">

                    <div class="logo">
                        🩺
                    </div>

                    <h3 class="fw-bold">
                        MediSlot
                    </h3>

                    <p class="text-muted">
                        Secure Clinic Booking System
                    </p>

                </div>

                <form method="post"
                      action="/Account/Login">

                    <div class="mb-3">

                        <label class="form-label">
                            Email
                        </label>

                        <input name="username"
                               class="form-control"
                               placeholder="example@email.com"
                               required />

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Password
                        </label>

                        <input type="password"
                               name="password"
                               class="form-control"
                               placeholder="Enter password"
                               required />
                    </div>

                    <button class="btn btn-dark w-100">
                        Sign In
                    </button>

                    <p class="text-danger mt-2 text-center">

                        @ViewBag.Error

                    </p>
                </form>
            </div>
        </div>
    </div>

</div>